# Same-origin API paths only (no https://… in the browser). Defaults if unset:
#   VITE_API_BASE_URL → /api/v1
#   VITE_AFFINE_SCORES_BASE_URL → /affine-io
# VITE_API_BASE_URL=/api/v1
# VITE_AFFINE_SCORES_BASE_URL=/affine-io

# Vite dev/preview: upstream for proxy /api (see vite.config.ts)
# VITE_DEV_PROXY_TARGET=https://api.affine.io

# --- Production behind nginx ---
# 1) Build (defaults already use relative paths):
#        npm run build
# 2) Serve dist/ and proxy:
#        /api/       → https://api.affine.io/api/
#        /affine-io/ → https://www.affine.io/api/affine/
#    See deploy/nginx-affine-dashboard.example.conf
# 3) Open http(s)://YOUR_HOST/ — Network tab should show only YOUR_HOST for API calls.
