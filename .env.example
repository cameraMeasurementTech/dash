# Full API base (no trailing slash). When set, overrides all defaults below.
# VITE_API_BASE_URL=https://api.affine.io/api/v1

# Dev: default is same-origin /api/v1 (Vite → api.affine.io). Avoids browser 403 from WAF.
# Dev only: call the API directly from the browser instead (often blocked from LAN).
# VITE_API_DIRECT=true

# Vite dev/preview: upstream for proxy /api (see vite.config.ts)
# VITE_DEV_PROXY_TARGET=https://api.affine.io

# --- Production behind nginx (fixes many 403 / WAF issues) ---
# 1) Use a RELATIVE base so the browser only talks to your nginx host:
#    VITE_API_BASE_URL=/api/v1 npm run build
# 2) Serve dist/ and proxy /api/ → https://api.affine.io/api/  (see deploy/nginx-affine-dashboard.example.conf)
# 3) Open http(s)://YOUR_HOST/ — Network tab should show /api/v1/... on YOUR_HOST, not api.affine.io
