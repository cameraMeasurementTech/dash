# Optional: full API base including /api/v1 (no trailing slash).
# Leave unset in dev to use Vite proxy: requests go to /api/v1 → https://api.affine.io/api/v1
# VITE_API_BASE_URL=https://api.affine.io/api/v1

# Dev only: origin for server.proxy /api (see vite.config.ts)
# VITE_DEV_PROXY_TARGET=https://api.affine.io
